# Twitch/IGDB API Credentials
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# Steam Web API Configuration
# Get your Steam API Key from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Get your Steam ID (64-bit) from: https://steamid.io/
STEAM_ID=your_steam_id_64_here

# Firebase Configuration (client-side, exposed to browser)
# Get these from: https://console.firebase.google.com/
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin (server-side, used by /api/*)
# From Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Ticket system / watch-time cron
# Numeric Twitch user id for the broadcaster (GooferG). Find via the helper script.
TWITCH_BROADCASTER_ID=your_broadcaster_id
# Refresh token from the broadcaster account with scope moderator:read:chatters
# Obtained by running: node scripts/get-broadcaster-refresh-token.mjs
TWITCH_BROADCASTER_REFRESH_TOKEN=your_refresh_token
# Shared secret for /api/cron/award-watchtime auth header
CRON_SECRET=some_long_random_string
# Optional: tickets awarded per cron tick to each active chatter (default 1)
WATCHTIME_TICKET_AWARD=1
# Optional: tickets per daily claim (default 10)
DAILY_TICKET_AWARD=10
