rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn()
        && request.auth.token.email == 'luimeneghim@gmail.com';
    }

    // Moderator = signed-in user whose Firebase uid (= Twitch user id for
    // viewer sign-ins) has an active admin_users/{uid} doc with role==moderator.
    function isMod() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'moderator'
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.active != false;
    }

    function isStaff() {
      return isOwner() || isMod();
    }

    // Legacy name kept for clarity in older rule lines below.
    function isAdmin() {
      return isStaff();
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- existing collections ---

    // Schedule doc — public read, staff write.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Game suggestions — public read, viewer can write only their own doc
    // (doc id == their twitchId == Firebase auth uid).
    match /suggestions/{uid} {
      allow read: if true;
      allow create, update: if isSelf(uid) || isStaff();
      allow delete: if isSelf(uid) || isStaff();
    }

    // --- store / tickets / giveaways (Phase 1+) ---

    // Users — owner can read their own doc, staff can read all.
    // The user doc itself is server-only; viewer-owned hunt subcollections
    // below are client-writable by the owner (self-gated, like suggestions).
    match /users/{uid} {
      allow read: if isSelf(uid) || isStaff();
      allow write: if false;

      // Bonus tracker — single in-progress hunt.
      match /active_hunt/{docId} {
        allow read, write: if isSelf(uid) || isStaff();
      }
      // Bonus tracker — completed hunts (track record).
      match /hunts/{huntId} {
        allow read, write: if isSelf(uid) || isStaff();
      }
    }

    // Store catalog — public read, owner-only write through server endpoint.
    match /store_items/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Redemptions — owner-of-redemption + staff read; writes server-only.
    match /redemptions/{id} {
      allow read: if isSignedIn()
        && (isStaff() || resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // Ticket ledger — owner-of-row + staff read; writes server-only.
    match /ticket_ledger/{id} {
      allow read: if isSignedIn()
        && (isStaff() || resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // Secrets (broadcaster refresh token, etc.) — never client-accessible.
    match /secrets/{id} {
      allow read, write: if false;
    }

    // Moderator allowlist — staff can read (so the admin shell can verify
    // the signed-in user is a mod). All writes server-only via
    // /api/admin/moderators (owner-gated).
    match /admin_users/{id} {
      allow read: if isStaff();
      allow write: if false;
    }

    // Audit logs of database wipes — owner-only read; writes server-only.
    match /reset_log/{id} {
      allow read: if isOwner();
      allow write: if false;
    }

    // Giveaways — public read of giveaway, entries, and winner_messages so
    // /giveaway and the admin modal can subscribe via onSnapshot. All writes
    // server-only.
    match /giveaways/{id} {
      allow read: if true;
      allow write: if false;
      match /entries/{entryId} {
        allow read: if true;
        allow write: if false;
      }
      match /winner_messages/{msgId} {
        allow read: if true;
        allow write: if false;
      }
      match /history/{historyId} {
        allow read: if isStaff();
        allow write: if false;
      }
    }

    // EventSub message dedupe cache — internal use only.
    match /eventsub_seen/{id} {
      allow read, write: if false;
    }

    // Hunts — unified collection for community hunts.
    match /hunts/{id} {
      allow read: if true;
      allow write: if false;
      match /entries/{entryId} {
        allow read: if true;
        allow write: if false;
      }
      match /suggestions/{sid} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Live-shared bonus hunt snapshots. The unguessable shareId is the access
    // capability, so reads are fully public (spectators, no login). Writes are
    // owner-only: a signed-in user may create/update/delete only a doc whose
    // ownerTwitchId matches their uid (= their Twitch id for viewer logins).
    match /shared_hunts/{shareId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.ownerTwitchId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.ownerTwitchId == request.auth.uid;
    }
  }
}
